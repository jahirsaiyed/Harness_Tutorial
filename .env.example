# LLM providers (at least one required for live agent runs)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Harness Agent state root (skills, memory, sessions, config)
HARNESS_AGENT_HOME=./labs

# Optional: path to external reference clone for notebook deep-dives
REFERENCE_REPO_PATH=

# Default provider: openai | anthropic
HARNESS_DEFAULT_PROVIDER=openai
HARNESS_DEFAULT_MODEL=gpt-4o-mini

# Gateway (ch15+)
HARNESS_GATEWAY_HOST=127.0.0.1
HARNESS_GATEWAY_PORT=8765
